{
  "name": "nursing-scheduler-api",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx src/config/seed.ts",
    "setup:admin": "tsx src/scripts/createFirstAdmin.ts",
    "test": "npm run test:unit && npm run test:api",
    "test:unit": "node --import tsx --test src/tests/rest.test.ts",
    "test:api": "node --import tsx --test src/tests/rules.api.test.ts && tsx src/scripts/isolation.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.11.0",
    "@sentry/node": "^10.58.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "pdf-lib": "^1.17.1",
    "prisma": "^5.11.0",
    "socket.io": "^4.7.5",
    "tsx": "^4.7.1",
    "twilio": "^5.0.3",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.30",
    "typescript": "^5.4.3"
  }
}
