# ─── NurseScheduler API — environment ───────────────────────────────────────
# Copy this to ".env" for local development. In production (Render), most of
# these are wired automatically by render.yaml; the rest you set in the
# dashboard (see DEPLOY-RENDER.md).

# Core
NODE_ENV=development
PORT=4000

# Web origins allowed to call the API (comma-separated, NO trailing slash).
# Local dev = the Vite web app + Expo. Production = your deployed web app origin.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081

# Base URL of the web app — used to build password-reset links inside emails.
APP_WEB_URL=http://localhost:5173

# PostgreSQL — Render provides this automatically in production.
DATABASE_URL="postgresql://postgres:password@localhost:5432/nursing_scheduler"

# Redis — background jobs / queues. Render provides this automatically.
REDIS_URL="redis://localhost:6379"

# Auth — MUST be a long random string in production (Render auto-generates one).
JWT_SECRET="change-me-in-production-use-a-long-random-string"

# Email (Resend). Leave RESEND_API_KEY unset to keep emails in dev-log mode.
# To go live: sign up at resend.com, verify your sending domain, then set both:
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM="NurseScheduler <noreply@yourdomain.com>"

# Optional — Twilio SMS alerts for sick call-ins (leave unset to disable).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Optional — Sentry error tracking (server crash/error reporting; unset = off).
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
