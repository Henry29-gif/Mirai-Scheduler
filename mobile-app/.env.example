# Mobile app environment variables (Expo SDK 54).
# Copy to `.env` for local development. EXPO_PUBLIC_* vars are inlined into the
# app at build time and are PUBLIC (visible in the shipped bundle) — never put
# secrets here.
#
# Local dev (phone on same Wi-Fi via Expo Go): your PC's LAN IP.
EXPO_PUBLIC_API_URL=http://192.168.1.109:4000
#
# For real builds, the value comes from eas.json per profile, NOT this file:
#   preview     -> https://api-staging.yourdomain.com
#   production  -> https://api.yourdomain.com   (HTTPS, hosted backend)
